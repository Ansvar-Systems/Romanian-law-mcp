{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Romanian Law MCP",
  "description": "Golden contract tests for Romanian official legislation ingestion",
  "tests": [
    {
      "id": "ro-001",
      "category": "article_retrieval",
      "description": "Retrieve Law 190/2018 Art. 1 from official GDPR implementation text",
      "tool": "get_provision",
      "input": {
        "document_id": "law-190-2018",
        "provision_ref": "Art.1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["datelor cu caracter personal", "Regulamentul (UE) 2016/679"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "ro-002",
      "category": "article_retrieval",
      "description": "Retrieve OUG 98/2010 Art. 1 (critical infrastructures)",
      "tool": "get_provision",
      "input": {
        "document_id": "oug-98-2010",
        "provision_ref": "Art.1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["infrastructurilor critice", "securității"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "ro-003",
      "category": "article_retrieval",
      "description": "Retrieve Criminal Code Art. 360 (illegal access)",
      "tool": "get_provision",
      "input": {
        "document_id": "law-286-2009-cyber",
        "provision_ref": "Art.360"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["sistem informatic", "fără drept"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "ro-004",
      "category": "article_retrieval",
      "description": "Retrieve Law 365/2002 Art. 11 (provider liability principles)",
      "tool": "get_provision",
      "input": {
        "document_id": "law-365-2002",
        "provision_ref": "Art.11"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["furnizorii de servicii", "răspund"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "ro-005",
      "category": "search",
      "description": "Search for personal data terms in Romanian legislation",
      "tool": "search_legislation",
      "input": {
        "query": "date cu caracter personal"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["date cu caracter personal"]
      }
    },
    {
      "id": "ro-006",
      "category": "search",
      "description": "Search for computer-system criminal provisions",
      "tool": "search_legislation",
      "input": {
        "query": "sistem informatic"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["sistem informatic"]
      }
    },
    {
      "id": "ro-007",
      "category": "search",
      "description": "Search for critical infrastructure provisions",
      "tool": "search_legislation",
      "input": {
        "query": "infrastructuri critice"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["infrastructuri critice"]
      }
    },
    {
      "id": "ro-008",
      "category": "citation_roundtrip",
      "description": "Citation URL for Law 190/2018 Art. 14 resolves to legislatie.just.ro",
      "tool": "get_provision",
      "input": {
        "document_id": "law-190-2018",
        "provision_ref": "Art.14"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "legislatie\\.just\\.ro",
        "text_not_empty": true
      }
    },
    {
      "id": "ro-009",
      "category": "citation_roundtrip",
      "description": "Citation URL for OUG 98/2010 Art. 1 resolves to legislatie.just.ro",
      "tool": "get_provision",
      "input": {
        "document_id": "oug-98-2010",
        "provision_ref": "Art.1"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "legislatie\\.just\\.ro",
        "text_not_empty": true
      }
    },
    {
      "id": "ro-010",
      "category": "eu_cross_reference",
      "description": "Law 190/2018 contains references to Regulation (EU) 2016/679",
      "tool": "get_eu_basis",
      "input": {
        "document_id": "law-190-2018"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["2016/679", "regulation"]
      }
    },
    {
      "id": "ro-011",
      "category": "negative_test",
      "description": "Non-existent Romanian law reference is handled gracefully",
      "tool": "get_provision",
      "input": {
        "document_id": "Legea nr. 9999/2099 privind lucruri fictive",
        "provision_ref": "Art.1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "ro-012",
      "category": "negative_test",
      "description": "Malformed article number is handled gracefully",
      "tool": "get_provision",
      "input": {
        "document_id": "law-190-2018",
        "provision_ref": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
